# Copy to docker/examples/.env.agent before running compose.
# Do not commit the copied file. Replace every "replace-with-..." value.

# Match the host user/group that can read mounted site files and logs.
AEGRAIL_AGENT_UID=1000
AEGRAIL_AGENT_GID=1000

# Host paths mounted read-only into the Agent container.
AEGRAIL_SITE_ROOT=/srv/example-wordpress
AEGRAIL_NGINX_LOG_DIR=/var/log/nginx

# Agent-side secrets and DSNs.
AEGRAIL_NODE_SECRET=replace-with-node-secret-from-hub
AEGRAIL_PII_KEY=replace-with-agent-side-hmac-key
AEGRAIL_DB_EXAMPLE_WORDPRESS_DSN=mysql://aegrail_readonly:replace-with-db-password@mysql-host:3306/example_wordpress?charset=utf8mb4

# Optional controls.
AEGRAIL_TOR_CHECK=1
AEGRAIL_CONFIG_COVERAGE_HEARTBEAT_INTERVAL=10m
AEGRAIL_WATCH_FULL_HASH_INTERVAL=1h
