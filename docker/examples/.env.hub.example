# Copy to docker/examples/.env.hub before running compose.
# Do not commit the copied file. Replace every "replace-with-..." value.

AEGRAIL_ENV=production
AEGRAIL_LOG_LEVEL=info
AEGRAIL_LOG_FORMAT=json
AEGRAIL_HTTP_PORT=8787
AEGRAIL_HUB_PUBLIC_URL=http://127.0.0.1:8787
AEGRAIL_POSTGRES_PASSWORD=replace-with-db-password

# Required Hub secrets.
# Generate wire key with:
# docker compose --env-file docker/examples/.env.hub -f docker/examples/hub.compose.yaml run --rm --no-deps hub wire keygen
AEGRAIL_HUB_WIRE_PRIVATE_KEY=replace-with-hub-wire-private-key
AEGRAIL_HUB_USER_SECRET=replace-with-strong-user-secret

AEGRAIL_HUB_WIRE_TIMESTAMP_SKEW=5m
AEGRAIL_REDIS_KEY_PREFIX=aegrail
AEGRAIL_CORRELATION_WORKERS=1
AEGRAIL_TRUSTED_PROXY_CIDRS=
# Temporary troubleshooting switch. Set true to log each ingest stage.
AEGRAIL_INGEST_DEBUG=false

# Optional notifications.
AEGRAIL_NOTIFICATION_WEBHOOK_URL=
AEGRAIL_NOTIFICATION_WEBHOOK_SECRET=
AEGRAIL_NOTIFICATION_WEBHOOK_TIMEOUT=5s

# Optional Mailjet SMTP email notifications. Username is the Mailjet API key;
# password is the Mailjet secret key.
AEGRAIL_NOTIFICATION_EMAIL_SMTP_HOST=in-v3.mailjet.com
AEGRAIL_NOTIFICATION_EMAIL_SMTP_PORT=587
AEGRAIL_NOTIFICATION_EMAIL_USERNAME=
AEGRAIL_NOTIFICATION_EMAIL_PASSWORD=
AEGRAIL_NOTIFICATION_EMAIL_FROM=
AEGRAIL_NOTIFICATION_EMAIL_TO=
AEGRAIL_NOTIFICATION_EMAIL_MIN_SEVERITY=medium
AEGRAIL_NOTIFICATION_EMAIL_EVENTS=finding.observed
AEGRAIL_NOTIFICATION_EMAIL_TIMEOUT=10s

# Optional browser push notifications. Generate keys with:
# docker compose --env-file docker/examples/.env.hub -f docker/examples/hub.compose.yaml run --rm --no-deps hub notifications vapid-keys
AEGRAIL_NOTIFICATION_PUSH_VAPID_PUBLIC_KEY=
AEGRAIL_NOTIFICATION_PUSH_VAPID_PRIVATE_KEY=
AEGRAIL_NOTIFICATION_PUSH_SUBJECT=
AEGRAIL_NOTIFICATION_PUSH_MIN_SEVERITY=medium
AEGRAIL_NOTIFICATION_PUSH_EVENTS=finding.observed
AEGRAIL_NOTIFICATION_PUSH_TTL=3600
AEGRAIL_NOTIFICATION_PUSH_TIMEOUT=10s

# Optional local model gateway.
AEGRAIL_OLLAMA_BASE_URL=http://host.docker.internal:11434
AEGRAIL_OLLAMA_INVESTIGATION_MODEL=
AEGRAIL_OLLAMA_INVESTIGATION_MODELS=qwen2.5-coder:14b,mistral-small3.2:latest,deepseek-coder-v2:16b,qwen3:14b,starcoder2:15b
AEGRAIL_OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
AEGRAIL_OLLAMA_OFFLINE=true
AEGRAIL_OLLAMA_TIMEOUT=5m
AEGRAIL_MODEL_ANALYSIS_AUTO=false
AEGRAIL_MODEL_ANALYSIS_INTERVAL=10m
AEGRAIL_MODEL_ANALYSIS_LIMIT=5
