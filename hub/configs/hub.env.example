AEGRAIL_ENV=local
AEGRAIL_LOG_LEVEL=debug
AEGRAIL_LOG_FORMAT=console
AEGRAIL_DATA_DIR=../data
AEGRAIL_MIGRATIONS_DIR=migrations
AEGRAIL_HTTP_ADDR=127.0.0.1:8787
AEGRAIL_HUB_PUBLIC_URL=http://127.0.0.1:8787
# Optional comma-separated CIDRs for trusted reverse proxies whose
# X-Forwarded-Proto/X-Forwarded-Host headers Hub may honor.
# Invalid CIDR entries make hub serve fail startup.
AEGRAIL_TRUSTED_PROXY_CIDRS=
AEGRAIL_HUB_WIRE_TIMESTAMP_SKEW=5m
# X25519 private key used to decrypt aegrail.agent.wire.v1 envelopes.
# Generate with: go run ./cmd/hub wire keygen
AEGRAIL_HUB_WIRE_PRIVATE_KEY=

# Required in serve mode. The local value below is for the bundled dev services.
AEGRAIL_DATABASE_URL=postgres://aegrail:aegrail@localhost:55432/aegrail?sslmode=disable
# Optional but recommended once several sites report to the same Hub.
# Hub uses Redis for short-lived ingest correlation jobs, distributed worker locks,
# and shared auth rate limiting.
# PostgreSQL remains the durable source of truth.
AEGRAIL_REDIS_URL=redis://localhost:56379/0
AEGRAIL_REDIS_KEY_PREFIX=aegrail
AEGRAIL_CORRELATION_WORKERS=2

# Optional finding notification webhook. Hub sends JSON when findings are observed
# and when an operator changes finding status. If a secret is set, requests include
# X-Aegrail-Signature: sha256=<hmac>.
AEGRAIL_NOTIFICATION_WEBHOOK_URL=
AEGRAIL_NOTIFICATION_WEBHOOK_SECRET=
AEGRAIL_NOTIFICATION_WEBHOOK_TIMEOUT=5s

# Optional Mailjet SMTP email notifications. Username is the Mailjet API key;
# password is the Mailjet secret key.
AEGRAIL_NOTIFICATION_EMAIL_SMTP_HOST=in-v3.mailjet.com
AEGRAIL_NOTIFICATION_EMAIL_SMTP_PORT=587
AEGRAIL_NOTIFICATION_EMAIL_USERNAME=
AEGRAIL_NOTIFICATION_EMAIL_PASSWORD=
AEGRAIL_NOTIFICATION_EMAIL_FROM=
AEGRAIL_NOTIFICATION_EMAIL_TO=
AEGRAIL_NOTIFICATION_EMAIL_MIN_SEVERITY=medium
AEGRAIL_NOTIFICATION_EMAIL_EVENTS=finding.observed
AEGRAIL_NOTIFICATION_EMAIL_TIMEOUT=10s

# Optional browser push notifications. Generate keys with:
# go run ./cmd/hub notifications vapid-keys
AEGRAIL_NOTIFICATION_PUSH_VAPID_PUBLIC_KEY=
AEGRAIL_NOTIFICATION_PUSH_VAPID_PRIVATE_KEY=
AEGRAIL_NOTIFICATION_PUSH_SUBJECT=
AEGRAIL_NOTIFICATION_PUSH_MIN_SEVERITY=medium
AEGRAIL_NOTIFICATION_PUSH_EVENTS=finding.observed
AEGRAIL_NOTIFICATION_PUSH_TTL=3600
AEGRAIL_NOTIFICATION_PUSH_TIMEOUT=10s

AEGRAIL_OLLAMA_BASE_URL=http://localhost:11434
# Optional hard override. Leave empty to use Aegrail's ranked local-model fallback list.
AEGRAIL_OLLAMA_INVESTIGATION_MODEL=
AEGRAIL_OLLAMA_INVESTIGATION_MODELS=qwen2.5-coder:14b,mistral-small3.2:latest,deepseek-coder-v2:16b,qwen3:14b,starcoder2:15b
AEGRAIL_OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
AEGRAIL_OLLAMA_OFFLINE=false
AEGRAIL_OLLAMA_TIMEOUT=5m
