AEGRAIL_ENV=local
AEGRAIL_LOG_LEVEL=debug
AEGRAIL_LOG_FORMAT=console
AEGRAIL_DATA_DIR=../data
AEGRAIL_MIGRATIONS_DIR=migrations
AEGRAIL_HTTP_ADDR=127.0.0.1:8787
AEGRAIL_HUB_INGEST_SECRET=change-me
AEGRAIL_HUB_INGEST_SIGNATURE_SKEW=5m

AEGRAIL_DATABASE_URL=postgres://aegrail:aegrail@localhost:55432/aegrail?sslmode=disable

AEGRAIL_OLLAMA_BASE_URL=http://localhost:11434
# Optional hard override. Leave empty to use Aegrail's ranked local-model fallback list.
AEGRAIL_OLLAMA_INVESTIGATION_MODEL=
AEGRAIL_OLLAMA_INVESTIGATION_MODELS=qwen2.5-coder:14b,mistral-small3.2:latest,deepseek-coder-v2:16b,qwen3:14b,starcoder2:15b
AEGRAIL_OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
AEGRAIL_OLLAMA_OFFLINE=false
AEGRAIL_OLLAMA_TIMEOUT=5m
