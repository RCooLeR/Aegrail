schema: aegrail.agent.server_config.v1

hub:
  url: http://127.0.0.1:8787
  ingest_secret_env: AEGRAIL_HUB_INGEST_SECRET
  send_limit: 100

identity:
  org: acme
  project: hosted-sites
  environment: production
  host: web-01
  agent_id: agt_web_01
  region: eu-central
  labels:
    role: web
    provider: vps

runtime:
  queue_dir: /var/lib/aegrail/queue
  state_dir: /var/lib/aegrail/state
  interval: 30s
  timezone: UTC

sites:
  - slug: example-com
    name: Example WordPress
    domain: example.com
    kind: wordpress
    app: example-com
    service: frontend
    root: /var/www/example.com
    labels:
      cms: wordpress
      tier: production
    files:
      profiles:
        - wordpress
      extra_paths:
        - /var/www/example.com/wp-content/mu-plugins
      exclude:
        - /var/www/example.com/wp-content/cache
    logs:
      - path: /var/log/nginx/example.com.access.log
        kind: nginx_access
      - path: /var/www/example.com/wp-content/debug.log
        kind: php_error
    databases:
      - name: wordpress
        engine: mysql
        dsn_env: AEGRAIL_DB_EXAMPLE_COM_DSN
        profile: wordpress
        table_prefix: wp_
        timeout: 10s
        schedule: 15m
    browser_crawl:
      enabled: true
      rendered: true
      wait_tag_manager: true
      max_pages: 8
      timeout: 30s
      urls:
        - https://example.com/
        - https://example.com/contact/

  - slug: example2-com
    name: Example2 PrestaShop
    domain: example2.com
    kind: prestashop
    app: example2-com
    service: frontend
    root: /var/www/example2.com
    labels:
      cms: prestashop
      tier: production
    files:
      profiles:
        - prestashop
    logs:
      - path: /var/log/nginx/example2.com.access.log
        kind: nginx_access
      - path: /var/www/example2.com/var/logs
        kind: php_error
    databases:
      - name: prestashop
        engine: mysql
        dsn_env: AEGRAIL_DB_EXAMPLE2_COM_DSN
        profile: prestashop
        table_prefix: ps_
        timeout: 10s
        schedule: 15m
    browser_crawl:
      enabled: true
      rendered: true
      wait_tag_manager: false
      max_pages: 8
      timeout: 30s
      urls:
        - https://example2.com/
        - https://example2.com/contact-us

  - slug: network-main
    name: Example WordPress Network
    domain: network.example.net
    kind: wordpress-multisite
    app: network-main
    service: frontend
    root: /var/www/network.example.net
    files:
      profiles:
        - wordpress
    databases:
      - name: wordpress_network
        engine: mysql
        dsn_env: AEGRAIL_DB_NETWORK_MAIN_DSN
        profile: wordpress
        table_prefix: wp_
        timeout: 10s
        schedule: 15m
    wordpress:
      multisite: true
      network_sites:
        - blog_id: 1
          domain: network.example.net
        - blog_id: 2
          domain: shop.network.example.net
    browser_crawl:
      enabled: true
      rendered: true
      wait_tag_manager: true
      max_pages: 12
      timeout: 45s
      urls:
        - https://network.example.net/
        - https://shop.network.example.net/
